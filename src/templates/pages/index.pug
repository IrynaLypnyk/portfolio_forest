extends ../template

block variables
    - var title = 'Добро пожаловать'

block content
    .welcome
        .welcome__auth-btn
            button.auth-btn Авторизоваться
        .welcome__flipper
            .welcome__user-block
                .user-block.form-container
                    include ../common/_user.pug
                    .welcome__socials

                    .welcome__nav-btns

            .welcome__auth-form
                .auth-form.form-container
                    .form__title.auth-form__title
                        .block-subtitle.block-subtitle_auth-form Авторизуйтесь
                    form.form(action="", method="get")
                        label.form__label.auth-form__label
                            input(type="text" placeholder="Логин").form__input.auth-form__input.auth-form__input_login
                            .form__input-fake.auth-form__input-fake.auth-form__input-fake_login

                        label.form__label.auth-form__label
                            input(type="password" placeholder="Пароль").form__input.auth-form__input.auth-form__input_pswd
                            .form__input-fake.auth-form__input-fake.auth-form__input-fake-pswd

                        label.form__checkbox-label.auth-form__checkbox-label
                            input(type="checkbox" checked).form__checkbox-input.auth-form__checkbox-input
                            .form__checkbox-fake.auth-form__checkbox-fake

                            .form__label-text.auth-form__label-text Я человек
                        .form__radio-block.auth-form__radio-block
                            .form__label-text.auth-form__label-text.auth-form__label-text_radio Вы точно не робот?
                            .form__radio-input-block.auth-form__radio-input-block
                                label.form__radio-label.auth-form__radio-label
                                    input(type="radio" name="isrobot" checked).form__radio-input.auth-form__radio-input
                                    .form__radio-fake.auth-form__radio-fake
                                    .form__label-text.auth-form__label-text Да
                                label.form__radio-label.auth-form__radio-label
                                    input(type="radio" name="isrobot").form__radio-input.auth-form__radio-input
                                    .form__radio-fake.auth-form__radio-fake
                                    .form__label-text.auth-form__label-text Я не уверен
                    .auth-form__nav-btns

        .welcome__copyright
            .copyright
                p.copyright__item &copy; Ирина Лыпник
                p.copyright__item создано с &#10084; в LoftSchool | 2017